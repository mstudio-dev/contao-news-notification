{
    "name": "mstudio-dev/contao-news-notification",
    "description": "Sends an email notification when a Contao news article is saved in the backend.",
    "version": "1.0.1",
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Markus Schnagl",
            "email": "mail@mstudio.de"
        }
    ],
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.0",
        "contao/news-bundle": "^5.0",
        "contao/manager-plugin": "^2.0",
        "symfony/mime": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Mstudio\\ContaoNewsNotificationBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Mstudio\\ContaoNewsNotificationBundle\\ContaoManager\\Plugin"
    }
}
